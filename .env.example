# Homelab Glue
PORT=8110
DATA_DIR=
UPLOAD_DIR=

# Security (set AUTH_MODE=basic for private deployments)
AUTH_MODE=off
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
VIEWER_USERNAME=
VIEWER_PASSWORD=
API_KEY=
CORS_ORIGINS=
TRUST_PROXY=false
RATE_LIMIT=240
UPLOAD_MAX_BYTES=10485760

# Operations
MONITORING_ENABLED=false
MONITORING_INTERVAL_SECONDS=300
NOTIFICATION_WEBHOOK_URL=
BACKUP_RETENTION=30

# Optional UniFi connector
UNIFI_ENABLED=false
UNIFI_HOST=https://10.0.0.1
UNIFI_USERNAME=
UNIFI_PASSWORD=
UNIFI_SITE=default
UNIFI_INSECURE_TLS=true
